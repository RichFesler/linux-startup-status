#!/usr/bin/env bash
set -u

# Portable Linux status banner for Raspberry Pi OS, Debian, Ubuntu, and Linux Mint.
# Intended for /etc/update-motd.d/99-linux-startup-status. Non-interactive by design.

if [ -t 1 ] && [ "${NO_COLOR:-0}" != "1" ]; then
  ESC=$'\033'
  RST="${ESC}[0m"
  LAB="${ESC}[1;37m"
  DOT="${ESC}[90m"
  TXT="${ESC}[0;37m"
  HDR="${ESC}[1;36m"
  OK="${ESC}[1;32m"
  WARN="${ESC}[1;33m"
  BAD="${ESC}[1;31m"
else
  RST=""; LAB=""; DOT=""; TXT=""; HDR=""; OK=""; WARN=""; BAD=""
fi

ln() { printf '%s\n' "$*"; }

line() {
  local label="$1" value="$2" width="${3:-30}"
  local n=$(( width - ${#label} ))
  [ "$n" -lt 1 ] && n=1
  local dots
  dots="$(printf '%*s' "$n" '' | tr ' ' '.')"
  ln "${LAB}${label}${DOT}${dots}${LAB}: ${TXT}${value}${RST}"
}

status_colorize() {
  local value="$1" mode="$2"
  case "$mode" in
    reboot)
      [ "$value" = "yes" ] && printf "%b%s%b" "$WARN" "$value" "$RST" || printf "%b%s%b" "$OK" "$value" "$RST"
      ;;
    ro)
      [ "$value" = "yes" ] && printf "%b%s%b" "$BAD" "$value" "$RST" || printf "%b%s%b" "$OK" "$value" "$RST"
      ;;
    wan|dns)
      [ "$value" = "ok" ] && printf "%b%s%b" "$OK" "$value" "$RST" || printf "%b%s%b" "$BAD" "$value" "$RST"
      ;;
    throttled)
      if [ "$value" = "n/a" ]; then
        printf "%s" "$value"
      elif [ "$value" = "0x0" ]; then
        printf "%b%s%b" "$OK" "$value" "$RST"
      else
        printf "%b%s%b" "$WARN" "$value" "$RST"
      fi
      ;;
    errors)
      if [ "$value" = "n/a" ]; then
        printf "%s" "$value"
      elif [ "$value" = "0" ]; then
        printf "%b%s%b" "$OK" "$value" "$RST"
      else
        printf "%b%s%b" "$WARN" "$value" "$RST"
      fi
      ;;
    failed)
      if [ "$value" = "0" ]; then
        printf "%b%s%b" "$OK" "$value" "$RST"
      else
        printf "%b%s%b" "$BAD" "$value" "$RST"
      fi
      ;;
    disk)
      if [ -n "${DISK_USE_PCT:-}" ] && [ "$DISK_USE_PCT" -ge 90 ] 2>/dev/null; then
        printf "%b%s%b" "$BAD" "$value" "$RST"
      elif [ -n "${DISK_USE_PCT:-}" ] && [ "$DISK_USE_PCT" -ge 80 ] 2>/dev/null; then
        printf "%b%s%b" "$WARN" "$value" "$RST"
      else
        printf "%s" "$value"
      fi
      ;;
    *)
      printf "%s" "$value"
      ;;
  esac
}

NOW="$(date '+%A, %d %B %Y, %-I:%M:%S %p %Z' 2>/dev/null || date)"
KERNEL="$(uname -srmo 2>/dev/null || uname -a)"
HOST="$(hostname 2>/dev/null || echo n/a)"

USER_NAME="$({ logname 2>/dev/null || true; } | head -n1)"
[ -z "${USER_NAME:-}" ] && USER_NAME="$(id -un 2>/dev/null || printf '%s' "${SUDO_USER:-${USER:-n/a}}")"

if [ -n "${SSH_TTY:-}" ]; then
  TTY_NAME="$(basename "$SSH_TTY")"
else
  TTY_NAME="local"
fi

UPTIME="$(uptime -p 2>/dev/null || echo n/a)"
LOAD="$(cut -d ' ' -f1-3 /proc/loadavg 2>/dev/null || echo n/a)"
PROCESS_COUNT="$(ps -e 2>/dev/null | wc -l | tr -d ' ')"
LOGIN_COUNT="$(who 2>/dev/null | awk 'NF{c++} END{print c+0}')"

ALL_IPS="$(hostname -I 2>/dev/null | xargs || echo n/a)"
PRIMARY_IP="$(printf '%s\n' $ALL_IPS 2>/dev/null | awk '
  $1 !~ /^127\./ &&
  $1 !~ /^169\.254\./ &&
  $1 !~ /^172\.(1[6-9]|2[0-9]|3[0-1])\./ { print $1; exit }
')"
[ -z "${PRIMARY_IP:-}" ] && PRIMARY_IP="$(printf '%s\n' $ALL_IPS 2>/dev/null | awk '{print $1; exit}')"
[ -z "${PRIMARY_IP:-}" ] && PRIMARY_IP="n/a"

MEMORY_LINE="n/a"
if command -v free >/dev/null 2>&1; then
  read -r MEM_TOTAL MEM_USED MEM_AVAIL <<EOF2
$(free -m | awk '/^Mem:/ {print $2, $3, $7}')
EOF2
  MEMORY_LINE="Total: ${MEM_TOTAL}MB  Used: ${MEM_USED}MB  Available: ${MEM_AVAIL}MB"
fi

DISK_LINE="n/a"
DISK_USE_PCT=""
if command -v df >/dev/null 2>&1; then
  read -r DISK_SIZE DISK_USED DISK_AVAIL DISK_USE <<EOF2
$(df -h / | awk 'NR==2{print $2, $3, $4, $5}')
EOF2
  DISK_LINE="${DISK_SIZE}  Used: ${DISK_USED}  Avail: ${DISK_AVAIL}  Use%: ${DISK_USE}"
  DISK_USE_PCT="${DISK_USE%\%}"
fi

TEMP_C=""
if command -v vcgencmd >/dev/null 2>&1; then
  TEMP_C="$(vcgencmd measure_temp 2>/dev/null | sed "s/temp=//; s/'C//")"
fi
if [ -z "$TEMP_C" ] && [ -r /sys/class/thermal/thermal_zone0/temp ]; then
  TEMP_C="$(awk '{printf "%.1f", $1/1000}' /sys/class/thermal/thermal_zone0/temp 2>/dev/null || true)"
fi
TEMP_LINE="n/a"
if [ -n "$TEMP_C" ]; then
  TEMP_LINE="$(awk -v c="$TEMP_C" 'BEGIN{printf "%.1f°F (%.1f°C)", (c*9/5)+32, c}')"
fi

ROOT_READ_ONLY="n/a"
if command -v findmnt >/dev/null 2>&1; then
  if findmnt -no OPTIONS / 2>/dev/null | grep -q '\<ro\>'; then
    ROOT_READ_ONLY="yes"
  else
    ROOT_READ_ONLY="no"
  fi
fi

THROTTLED_STATE="n/a"
if command -v vcgencmd >/dev/null 2>&1; then
  THROTTLED_STATE="$(vcgencmd get_throttled 2>/dev/null | awk -F= '{print $2}')"
fi

PENDING_UPDATES="n/a"
if command -v apt-get >/dev/null 2>&1; then
  STAMP=/run/linux-startup-status-updates.stamp
  CACHE=/run/linux-startup-status-updates.count
  if [ -f "$CACHE" ] && [ -f "$STAMP" ] && [ $(( $(date +%s) - $(stat -c %Y "$STAMP") )) -le 3600 ]; then
    PENDING_UPDATES="$(cat "$CACHE" 2>/dev/null || echo 0)"
  else
    PENDING_UPDATES="$(apt-get -s upgrade 2>/dev/null | awk '/^Inst /{c++} END{print c+0}')"
    printf "%s" "$PENDING_UPDATES" > "$CACHE" 2>/dev/null || true
    : > "$STAMP" 2>/dev/null || true
  fi
fi

REBOOT_REQUIRED="no"
[ -f /var/run/reboot-required ] && REBOOT_REQUIRED="yes"

GATEWAY="$(ip route 2>/dev/null | awk '/default/ {print $3; exit}')"
[ -z "${GATEWAY:-}" ] && GATEWAY="n/a"

WAN_STATUS="n/a"
DNS_STATUS="n/a"
if command -v ping >/dev/null 2>&1; then
  ping -c1 -W1 1.1.1.1 >/dev/null 2>&1 && WAN_STATUS="ok" || WAN_STATUS="fail"
fi
getent hosts google.com >/dev/null 2>&1 && DNS_STATUS="ok" || DNS_STATUS="fail"

JOURNAL_ERRORS="n/a"
if command -v journalctl >/dev/null 2>&1; then
  JOURNAL_ERRORS="$(journalctl -b -p err --no-pager 2>/dev/null | grep -c . || true)"
fi
FAILED_UNITS="$(systemctl --failed --no-legend 2>/dev/null | awk 'NF{c++} END{print c+0}')"

ln ""
ln "${HDR}${NOW}${RST}"
ln "${HDR}${KERNEL}${RST}"
ln ""
line "Host" "$HOST"
line "User" "$USER_NAME"
line "TTY" "$TTY_NAME"
ln ""
line "Uptime" "$UPTIME"
line "Load Averages" "$LOAD (1, 5, 15 min)"
line "Memory" "$MEMORY_LINE"
line "Disk" "$(status_colorize "$DISK_LINE" disk)"
line "Primary IP" "$PRIMARY_IP"
line "All IPs" "$ALL_IPS"
line "CPU Temp" "$TEMP_LINE"
line "Throttled" "$(status_colorize "$THROTTLED_STATE" throttled) $( [ "$THROTTLED_STATE" != "n/a" ] && printf '(0x0=clean)' )"
line "Root FS read-only" "$(status_colorize "$ROOT_READ_ONLY" ro)"
line "Updates pending" "$PENDING_UPDATES"
line "Reboot required" "$(status_colorize "$REBOOT_REQUIRED" reboot)"
line "Gateway" "$GATEWAY"
line "WAN ping" "$(status_colorize "$WAN_STATUS" wan)"
line "DNS" "$(status_colorize "$DNS_STATUS" dns)"
line "Journal errors" "$(status_colorize "$JOURNAL_ERRORS" errors)"
line "Failed units" "$(status_colorize "$FAILED_UNITS" failed)"
line "Running Processes" "$PROCESS_COUNT"
line "Users logged in" "$LOGIN_COUNT"
ln ""
